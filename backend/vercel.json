{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/v/(.*)",
      "destination": "/v/$1"
    },
    {
      "source": "/",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 10
    },
    "api/[...slug].js": {
      "maxDuration": 10
    },
    "v/[vehicleId].js": {
      "maxDuration": 10
    }
  }
}
